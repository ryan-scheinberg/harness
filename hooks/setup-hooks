#!/usr/bin/env python3
"""
Build + install the safety-hooks gates.

Two install targets, built from the same repo:

  1. Cowork plugin — zipped as dist/safety-hooks.plugin. Drag that file into
     a Cowork chat to install/update, then restart Cowork. Plugin paths use
     ${CLAUDE_PLUGIN_ROOT} so Cowork resolves scripts inside the plugin.

  2. Claude Code CLI — merged into ~/.claude/settings.json with absolute
     paths pointing at this repo's scripts/ directory. Claude Code does NOT
     auto-discover plugins from ~/.claude/plugins/, but it does read hooks
     from the user-scope settings.json and merges them across layers, so
     this is the canonical install path for the CLI.

Skip either target with --no-plugin or --no-claude-code. --dry-run prints
what would happen without touching disk.
"""
from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
import time
import zipfile
from pathlib import Path

PLUGIN_NAME = "safety-hooks"
PLUGIN_DESCRIPTION = (
    "Safety hooks that gate destructive bash commands and MCP write operations. "
    "Requires explicit per-call approval for package installs, git history "
    "rewrites, AWS writes, secrets access, production deploys, and any "
    "outbound MCP write (email send, Slack post, GitLab issue create, etc.)."
)
PLUGIN_AUTHOR = "Ryan Scheinberg"
DIST_DIRNAME = "dist"

# ~/.claude is the user-scope Claude Code config dir. settings.json here is
# merged with project and local layers; hooks from all layers run.
CLAUDE_HOME = Path.home() / ".claude"
CC_SETTINGS = CLAUDE_HOME / "settings.json"


def build(repo_root: Path, dry_run: bool) -> Path:
    dist_dir = repo_root / DIST_DIRNAME
    plugin_file = dist_dir / f"{PLUGIN_NAME}.plugin"
    stage_dir = dist_dir / f".stage-{PLUGIN_NAME}"
    version = f"0.1.{int(time.time())}"

    if dry_run:
        print(f"would build {plugin_file} (name={PLUGIN_NAME}, version={version})")
        return plugin_file

    dist_dir.mkdir(exist_ok=True)
    if stage_dir.exists():
        shutil.rmtree(stage_dir)
    stage_dir.mkdir(parents=True)

    # .claude-plugin/plugin.json — manifest
    manifest_dir = stage_dir / ".claude-plugin"
    manifest_dir.mkdir()
    manifest = {
        "name": PLUGIN_NAME,
        "version": version,
        "description": PLUGIN_DESCRIPTION,
        "author": {"name": PLUGIN_AUTHOR},
        "hooks": "./hooks/hooks.json",
    }
    (manifest_dir / "plugin.json").write_text(
        json.dumps(manifest, indent=2) + "\n"
    )

    # hooks/hooks.json — PreToolUse / PostToolUse wiring
    hooks_stage = stage_dir / "hooks"
    hooks_stage.mkdir()
    shutil.copy2(repo_root / "hooks.json", hooks_stage / "hooks.json")

    # scripts/ — the actual hook logic
    src_scripts = repo_root / "scripts"
    dst_scripts = stage_dir / "scripts"
    shutil.copytree(
        src_scripts,
        dst_scripts,
        ignore=shutil.ignore_patterns("__pycache__", "*.pyc", ".pytest_cache", ".DS_Store"),
    )

    # Zip
    plugin_file.unlink(missing_ok=True)
    zip_bin = shutil.which("zip")
    if zip_bin:
        subprocess.run(
            [zip_bin, "-r", "-q", str(plugin_file), "."],
            check=True,
            cwd=str(stage_dir),
        )
    else:
        with zipfile.ZipFile(plugin_file, "w", zipfile.ZIP_DEFLATED) as zf:
            for root, _, files in os.walk(stage_dir):
                for f in files:
                    abs_f = Path(root) / f
                    zf.write(abs_f, abs_f.relative_to(stage_dir))

    shutil.rmtree(stage_dir)
    return plugin_file


def _is_our_block(block: dict, repo_root: Path) -> bool:
    """A hook block is ours iff any of its commands reference this repo's
    scripts/ directory by absolute path. Used to strip stale entries on
    re-install so we don't accumulate duplicates."""
    marker = str(repo_root / "scripts")
    for h in block.get("hooks", []) or []:
        if marker in (h.get("command") or ""):
            return True
    return False


def install_into_claude_code(repo_root: Path, dry_run: bool) -> Path | None:
    """Merge hooks.json into ~/.claude/settings.json with ${CLAUDE_PLUGIN_ROOT}
    rewritten to this repo's absolute path. Idempotent: prior installs keyed
    on our scripts/ path are stripped before the fresh blocks are appended.

    Fail-open: any error here should not prevent the Cowork .plugin build
    from being usable. We log and return None.
    """
    hooks_src = repo_root / "hooks.json"
    if not hooks_src.exists():
        print(f"[claude-code] skipped: {hooks_src} not found", file=sys.stderr)
        return None

    try:
        hooks_doc = json.loads(hooks_src.read_text())
    except Exception as e:
        print(f"[claude-code] skipped: failed to parse hooks.json: {e}", file=sys.stderr)
        return None

    # Swap plugin-relative paths for absolute paths. Using str replacement on
    # the serialized JSON is fine — CLAUDE_PLUGIN_ROOT only appears inside
    # command strings and is never a legitimate substring elsewhere.
    rewritten_json = json.dumps(hooks_doc).replace(
        "${CLAUDE_PLUGIN_ROOT}", str(repo_root)
    )
    rewritten = json.loads(rewritten_json)

    # Load existing settings.json (or start empty). If the file exists but
    # is invalid JSON, refuse to clobber — surface the error and bail.
    if CC_SETTINGS.exists():
        raw = CC_SETTINGS.read_text().strip() or "{}"
        try:
            existing = json.loads(raw)
        except Exception as e:
            print(
                f"[claude-code] aborted: {CC_SETTINGS} is not valid JSON "
                f"({e}); fix or remove it and re-run.",
                file=sys.stderr,
            )
            return None
    else:
        existing = {}

    if not isinstance(existing, dict):
        print(f"[claude-code] aborted: {CC_SETTINGS} is not a JSON object", file=sys.stderr)
        return None

    existing_hooks = existing.setdefault("hooks", {})
    if not isinstance(existing_hooks, dict):
        print(f"[claude-code] aborted: 'hooks' in {CC_SETTINGS} is not an object", file=sys.stderr)
        return None

    # Strip any prior blocks we own, per phase.
    for phase in ("PreToolUse", "PostToolUse"):
        cur = existing_hooks.get(phase, []) or []
        existing_hooks[phase] = [b for b in cur if not _is_our_block(b, repo_root)]

    # Append the fresh blocks.
    for phase, new_blocks in (rewritten.get("hooks") or {}).items():
        existing_hooks.setdefault(phase, []).extend(new_blocks)

    # Drop now-empty phases so we don't leave empty arrays behind.
    for phase in list(existing_hooks.keys()):
        if not existing_hooks[phase]:
            del existing_hooks[phase]

    if dry_run:
        total = sum(len(v) for v in existing_hooks.values())
        print(f"[claude-code] would write {CC_SETTINGS} with {total} hook blocks")
        return CC_SETTINGS

    CLAUDE_HOME.mkdir(parents=True, exist_ok=True)
    # Write via a temp file + rename for atomicity on the local FS. Not
    # strictly required but cheap insurance against partial writes.
    tmp = CC_SETTINGS.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(existing, indent=2) + "\n")
    os.replace(tmp, CC_SETTINGS)
    return CC_SETTINGS


def main() -> int:
    argv = sys.argv[1:]
    dry_run = "--dry-run" in argv
    do_plugin = "--no-plugin" not in argv
    do_claude_code = "--no-claude-code" not in argv

    repo_root = Path(__file__).resolve().parent

    if do_plugin:
        plugin_file = build(repo_root, dry_run)
        print(f"Built: {plugin_file}")
        print(
            "Cowork install: drag the .plugin file into Cowork chat and accept. "
            "Then fully quit & reopen Cowork.",
            file=sys.stderr,
        )

    if do_claude_code:
        cc_path = install_into_claude_code(repo_root, dry_run)
        if cc_path is not None:
            verb = "Would install" if dry_run else "Installed"
            print(f"{verb} Claude Code hooks: {cc_path}", file=sys.stderr)
            print(
                "Claude Code install: no restart needed — hooks load on the "
                "next session. Verify with `cat ~/.claude/settings.json`.",
                file=sys.stderr,
            )

    if not (do_plugin or do_claude_code):
        print("Nothing to do: both targets disabled.", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
